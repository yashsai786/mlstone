# FastAPI Service Settings
API_HOST=0.0.0.0
API_PORT=8000

# ZeroMQ Broker Settings
# Use tcp://127.0.0.1:5555 for local or tcp://0.0.0.0:5555 for Docker/Distributed
ZMQ_BROKER_URL=tcp://127.0.0.1:5555
ZMQ_RESPONSE_TIMEOUT_MS=15000

# Storage Settings
STORAGE_BASE_DIR=./storage

# Downloader Settings
# 10MB in bytes = 10485760
MAX_DOWNLOAD_SIZE_BYTES=10485760
DOWNLOAD_TIMEOUT_SECONDS=10

# Preprocessing Settings
MIN_SLAB_AREA_RATIO=0.05
DEBUG_MODE=True
